<?xml version="1.0"?>
<sdf version="1.8">
    <model name="Reflective table">
        <static>true</static>
        <link name="link">
            <pose>0 0 0 0 3.14 0</pose>
            <collision name="collision">
                <geometry>
                    <!-- table dimensions already scaled (0.6 0.6 0.6) -->
                    <box>
                        <size>2.393664 1.553142 1.039566</size>
                    </box>
                </geometry>
            </collision>
            <visual name="visual">
                <geometry>
                    <mesh>
                        <scale>0.6 0.6 0.6</scale>
                        <uri>meshes/Table.dae</uri>
                    </mesh>
                </geometry>
                <material>
                    <diffuse>1.0 1.0 1.0</diffuse>
                    <ambient>0.5 0.5 0.5 1.0</ambient>
                    <!-- ? simplify table rendering -->
                    <!-- <pbr>
                        <metal>
                            <albedo_map>materials/textures/Table_Table_BaseColor.png</albedo_map>
                            <normal_map>materials/textures/Table_Table_Normal.png</normal_map>
                            <roughness_map>materials/textures/Table_Roughness.png</roughness_map>
                            <environment_map>materials/textures/DepotEnvMap.dds</environment_map>
                            <metalness>0.1</metalness>
                        </metal>
                    </pbr> -->
                </material>
            </visual>
        </link>
    </model>
</sdf>
